# URL di connessione al database PostgreSQL
# Copiala da Railway dopo aver creato il plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Telegram Bot (opzionale) — per ricevere alert code basse
# Crea un bot con @BotFather e copia il token qui
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (opzionale) Invia sommario top 5 code basse ad ogni ciclo
# TELEGRAM_SEND_SUMMARY=true
